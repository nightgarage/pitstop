# Pitstop configuration — every setting is an environment variable.
# Copy to .env and adjust. All values shown are the defaults.

# Secret used to sign login tokens. If unset, Pitstop generates one on first
# start and stores it in DATA_DIR/.secret_key (fine for most self-hosts).
#SECRET_KEY=

# Where the SQLite database and generated secret live. Inside Docker this is
# the /data volume; leave it alone unless you know why.
#DATA_DIR=/data

# Database. Empty = SQLite file in DATA_DIR. For Postgres, e.g.:
#DATABASE_URL=postgresql+psycopg://pitstop:pitstop@db:5432/pitstop

# Allow people to create their own accounts. Keep false for a private
# instance; the first-run admin account is always allowed.
#ALLOW_REGISTRATION=false

# Set true when Pitstop is served over HTTPS (marks the login cookie Secure).
#COOKIE_SECURE=false

# Serve under a subpath behind a reverse proxy, e.g. /pitstop
#BASE_PATH=

# How long a login stays valid, in days.
#ACCESS_TOKEN_EXPIRE_DAYS=30

# Create a demo account (demo@example.com / pitstop-demo) with sample data on
# first start. Only runs when the instance has no users yet.
#SEED_DEMO=false

# Outgoing email for the optional email notification channel. Unset = email
# delivery is off (in-app, ntfy, Gotify, and webhooks work regardless).
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=pitstop@example.com
#SMTP_TLS=true
